BTCUSD//@version=6
// Contrarian Golden/Death Cross — 5m Strategy
// Marks exact buy/sell signals on chart for BTC, ETH, SOL, AKT
// Matches the live bot conditions exactly.

indicator("Contrarian G/D Cross 5m", overlay=true, max_labels_count=500)

// ─── Inputs ──────────────────────────────────────────────────────────────────
sma_fast_len  = input.int(50,  "Fast SMA",  group="Regime")
sma_slow_len  = input.int(200, "Slow SMA",  group="Regime")
rsi_len       = input.int(14,  "RSI Length",       group="Indicators")
rsi_buy_th    = input.int(38,  "RSI Buy Threshold",  group="Indicators")
rsi_sell_th   = input.int(62,  "RSI Sell Threshold", group="Indicators")
bb_len        = input.int(20,  "BB Period",   group="Indicators")
bb_std        = input.float(2.0,"BB Std Dev", group="Indicators")
show_mas      = input.bool(true,"Show SMA50/200", group="Display")
show_bb       = input.bool(true,"Show Bollinger Bands", group="Display")

// ─── Regime ──────────────────────────────────────────────────────────────────
sma50  = ta.sma(close, sma_fast_len)
sma200 = ta.sma(close, sma_slow_len)

death_cross  = sma50 < sma200  // BUY regime (contrarian)
golden_cross = sma50 > sma200  // SELL regime (contrarian)

// Regime change events
death_cross_event  = ta.crossunder(sma50, sma200)
golden_cross_event = ta.crossover(sma50, sma200)

// ─── Indicators ──────────────────────────────────────────────────────────────
rsi14               = ta.rsi(close, rsi_len)
[bb_mid, bb_upper, bb_lower] = ta.bb(close, bb_len, bb_std)
[macd_line, signal_line, histogram] = ta.macd(close, 12, 26, 9)
vwap_val            = ta.vwap(hlc3)
obv_val             = ta.obv

// MACD direction
macd_rising  = histogram > histogram[1]
macd_falling = histogram < histogram[1]

// OBV direction (over 3 candles = 15min)
obv_rising  = obv_val > obv_val[3]
obv_falling = obv_val < obv_val[3]

// ─── Signal Conditions ───────────────────────────────────────────────────────

// BUY: death cross regime + RSI oversold + price at lower BB + 1 confirmation
buy_base    = death_cross and rsi14 < rsi_buy_th and close <= bb_lower