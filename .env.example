# ─────────────────────────────────────────────────────────────────────────────
#  Craig Accumulation Bot v2  —  Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ─────────────────────────────────────────────────────────────────
# Create a bot via @BotFather, then message @userinfobot for your chat ID.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Coinbase Advanced Trade API ───────────────────────────────────────────────
# Create a CDP API key at https://portal.cdp.coinbase.com/
# Permissions needed: View + Trade (Spot). No Transfer/Withdrawal needed.
# COINBASE_API_KEY  — the key name, e.g. "organizations/xxx/apiKeys/yyy"
# COINBASE_PRIVATE_KEY — the EC private key PEM, newlines as literal \n
COINBASE_API_KEY=organizations/your-org-id/apiKeys/your-key-id
COINBASE_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----\nYOUR_BASE64_ENCODED_KEY_HERE\n-----END EC PRIVATE KEY-----

# ── Live trading flag ─────────────────────────────────────────────────────────
# false (default) = paper mode — simulates trades at bar-close price, no real orders
# true            = live mode  — places real market orders on Coinbase
# IMPORTANT: set COINBASE_API_KEY + COINBASE_PRIVATE_KEY before enabling live mode
LIVE_TRADING=false
